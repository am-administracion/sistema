  const tbody = document.getElementById('tickets-tbody');
  if (!data?.length) { tbody.innerHTML = '<tr><td colspan="4" class="empty-state">No hay tickets</td></tr>'; return; }
  tbody.innerHTML = data.map(g=>`<tr><td>${fd(g.fecha)}</td><td class="td-main">${g.descripcion||'—'}</td><td><span class="chip chip-blue">${g.categoria||'—'}</span></td><td style="font-family:var(--mono);color:var(--green)">${fp(g.monto)}</td></tr>`).join('');
}

function handleTicketFile(input) {
  const file = input.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('preview-img').src = e.target.result;
    document.getElementById('ticket-preview').style.display = 'block';
    analyzeTicket(e.target.result);
  };
  reader.readAsDataURL(file);
}

async function analyzeTicket(imageData) {
  document.getElementById('ticket-loading').style.display = 'block';
  document.getElementById('ticket-result').style.display = 'none';
  const bar = document.getElementById('ai-progress');
  bar.style.width = '0%';
  setTimeout(()=>bar.style.width='60%',100);
  setTimeout(()=>bar.style.width='90%',1200);
  try {
    const base64 = imageData.split(',')[1];
    const mtype = imageData.split(';')[0].split(':')[1]||'image/jpeg';
    const res = await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:400,messages:[{role:'user',content:[{type:'image',source:{type:'base64',media_type:mtype,data:base64}},{type:'text',text:'Analizá este ticket. Respondé SOLO con JSON (sin backticks): {"comercio":"nombre","fecha":"dd/mm/yyyy","monto":"$X.XXX","categoria":"Materiales|Combustible|Herramientas|Alimentos|Hospedaje|Otro","monto_numero":NUMERO}'}]}]})});
    const d = await res.json();
    const txt = (d.content||[]).map(c=>c.text||'').join('');
    try { ticketData = JSON.parse(txt.replace(/```json|```/g,'').trim()); }
    catch { ticketData = {comercio:'No detectado',fecha:'—',monto:'—',categoria:'Otro',monto_numero:0}; }
    bar.style.width='100%';
    setTimeout(()=>{
      document.getElementById('ticket-loading').style.display='none';
      document.getElementById('tr-comercio').textContent=ticketData.comercio;
      document.getElementById('tr-fecha-t').textContent=ticketData.fecha;
      document.getElementById('tr-monto').textContent=ticketData.monto;
      document.getElementById('tr-cat').textContent=ticketData.categoria;
      document.getElementById('ticket-result').style.display='block';
    },300);
  } catch(e) {
    bar.style.width='100%';
    setTimeout(()=>{document.getElementById('ticket-loading').style.display='none';document.getElementById('tr-comercio').textContent='Error de conexión';document.getElementById('ticket-result').style.display='block';},300);
  }
}

async function confirmarTicket() {
  if (!ticketData||!currentUsuario) return;
  await db.from('gastos').insert({categoria:document.getElementById('ticket-cat').value,descripcion:ticketData.comercio,monto:ticketData.monto_numero||0,fecha:new Date().toISOString().split('T')[0],registrado_por:currentUsuario.id});
  showToast('Ticket guardado ✓','success'); loadTickets();
  document.getElementById('ticket-result').style.display='none';
  document.getElementById('ticket-preview').style.display='none';
  ticketData=null;
}

