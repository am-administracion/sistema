async function enviarReporte() {
  const obraId = document.getElementById('rpt-obra-id').value;
  const fecha = document.getElementById('rpt-fecha').value;
  if (!obraId || !fecha || !currentUsuario) { showToast('Completá obra y fecha', 'error'); return; }

  const btn = document.getElementById('btn-enviar');
  btn.disabled = true; btn.innerHTML = '<div class="spinner"></div> Guardando...';

  // Geolocalización
  let lat = null, lng = null;
  if (navigator.geolocation) {
    try {
      const pos = await new Promise((res,rej) => navigator.geolocation.getCurrentPosition(res,rej,{timeout:4000}));
      lat = pos.coords.latitude; lng = pos.coords.longitude;
    } catch(e) {}
  }

  // Calcular producción para KPI automático
  const prodItems = document.getElementById('produccion-list').querySelectorAll('.produccion-item');
  let totalPrevisto = 0, totalRealizado = 0;
  prodItems.forEach(item => {
    const inputs = item.querySelectorAll('input[type=number]');
    totalPrevisto += parseFloat(inputs[0]?.value)||0;
    totalRealizado += parseFloat(inputs[1]?.value)||0;
  });
  const rendimiento = totalPrevisto > 0 ? Math.min(100, Math.round(totalRealizado/totalPrevisto*100)) : 75;
  const fotos = document.getElementById('foto-grid').children.length;
  const kpiAuto = Math.min(100, Math.round(rendimiento*0.6 + Math.min(fotos,5)*4 + 20));
  const bonoPct = kpiBono(kpiAuto);
  const huboInc = document.getElementById('inconveniente-sel').value === 'si';

  // Avance estimado
  const avanceEstimado = Math.min(100, Math.round(rendimiento * 0.8));

  const { data: reporte, error } = await db.from('reportes').insert({
    obra_id: obraId,
    encargado_id: currentUsuario.id,
    fecha, avance_dia: avanceEstimado,
    kpi_total: kpiAuto, bono_porcentaje: bonoPct,
    hubo_inconveniente: huboInc,
    descripcion_inconveniente: huboInc ? document.getElementById('rpt-inconveniente').value : null,
    notas: document.getElementById('rpt-notas').value,
    ubicacion_lat: lat, ubicacion_lng: lng
  }).select().single();

  if (error) {
    showToast(error.code==='23505'?'Ya existe reporte para esta obra y fecha':'Error: '+error.message, 'error');
    btn.disabled=false; btn.textContent='Enviar reporte del día'; return;
  }

  // Guardar gastos
  const gastoRows = document.getElementById('gastos-list').querySelectorAll('div');
  for (const fila of gastoRows) {
    const sel = fila.querySelector('select');
    const inps = fila.querySelectorAll('input');
    if (sel && inps[1]?.value) {
      await db.from('gastos').insert({ reporte_id:reporte.id, obra_id:obraId, categoria:sel.value, descripcion:inps[0]?.value||'', monto:parseFloat(inps[1].value), fecha, registrado_por:currentUsuario.id });
    }
  }
  await db.from('obras').update({ avance_total: avanceEstimado }).eq('id', obraId);

  btn.disabled=false; btn.textContent='Enviar reporte del día';
  showToast(`Reporte guardado ✓ KPI automático: ${kpiAuto}`, 'success');
  loadReportesRecientes(); loadDashboard(); loadKanban();
}

