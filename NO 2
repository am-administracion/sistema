async function loadDashboard() {
  const today = new Date().toISOString().split('T')[0];
  const { data: obras } = await db.from('obras').select('*').in('estado', ['en_curso','demorada','iniciando','cotizacion','adjudicada']);
  const activas = obras?.filter(o => ['en_curso','demorada','iniciando'].includes(o.estado)) || [];
  document.getElementById('dash-obras').textContent = activas.length;
  document.getElementById('dash-obras-sub').textContent = `${obras?.length||0} en total`;

  const { data: repHoy } = await db.from('reportes').select('id').eq('fecha', today);
  document.getElementById('dash-rep-hoy').textContent = repHoy?.length ?? 0;

  const { data: repRec } = await db.from('reportes').select('kpi_total').order('created_at',{ascending:false}).limit(10);
  const kpiProm = repRec?.length ? Math.round(repRec.reduce((a,r)=>a+(r.kpi_total||0),0)/repRec.length) : '—';
  document.getElementById('dash-kpi').textContent = kpiProm;

  const { data: vias } = await db.from('viaticos').select('id').in('estado',['pendiente','parcial']);
  document.getElementById('dash-via').textContent = vias?.length ?? 0;

  // Obras list
  const el = document.getElementById('dash-obras-list');
  if (!activas.length) { el.innerHTML = '<div class="empty-state"><div class="empty-icon">🏗️</div>No hay obras activas</div>'; }
  else { el.innerHTML = activas.map(o => `
    <div class="obra-card" onclick="openObraDetail('${o.id}')">
      <div class="obra-header"><div><div class="obra-name">${o.nombre} — ${o.ubicacion||''}</div><div class="obra-meta">${o.cliente} · ${fp(o.presupuesto)}</div></div>${estadoChip(o.estado)}</div>
      <div class="obra-bar-label"><span>Avance</span><span>${o.avance_total||0}%</span></div>
      <div class="progress"><div class="progress-fill" style="width:${o.avance_total||0}%;background:${o.estado==='demorada'?'var(--amber)':'var(--green)'}"></div></div>
    </div>`).join(''); }

  // Alertas
  const aEl = document.getElementById('dash-alertas');
  const alertas = [];
  activas.filter(o=>o.estado==='demorada').forEach(o => alertas.push(`<div style="display:flex;gap:8px;padding:8px;background:rgba(245,158,11,0.07);border-radius:8px;border:1px solid rgba(245,158,11,0.15)"><span style="color:var(--amber)">⚠</span><div><div style="font-size:12px;font-weight:500;color:var(--text)">${o.nombre}</div><div style="font-size:11px;color:var(--text3)">Demorada · ${o.ubicacion}</div></div></div>`));
  if (repHoy?.length) alertas.push(`<div style="display:flex;gap:8px;padding:8px;background:rgba(16,185,129,0.07);border-radius:8px;border:1px solid rgba(16,185,129,0.15)"><span style="color:var(--green)">✓</span><div style="font-size:12px;color:var(--text)">${repHoy.length} reporte${repHoy.length>1?'s':''} recibido${repHoy.length>1?'s':''} hoy</div></div>`);
  aEl.innerHTML = alertas.length ? alertas.join('') : '<div class="empty-state">Sin alertas</div>';

  // Últimos reportes
  const { data: ur } = await db.from('reportes').select('fecha,obras(nombre),usuarios(nombre),kpi_total').order('created_at',{ascending:false}).limit(4);
  const urEl = document.getElementById('dash-ult-rep');
  if (!ur?.length) { urEl.innerHTML = '<div class="empty-state">Sin reportes aún</div>'; return; }
  urEl.innerHTML = ur.map(r => `
    <div style="display:flex;justify-content:space-between;padding:8px;background:var(--surface2);border-radius:6px">
      <div><div style="color:var(--text);font-weight:500;font-size:12px">${r.obras?.nombre||'—'}</div><div style="color:var(--text3);font-size:11px">${fd(r.fecha)} · ${r.usuarios?.nombre?.split(' ')[0]||'—'}</div></div>
      ${r.kpi_total ? kpiChip(r.kpi_total) : '<span class="chip chip-gray">—</span>'}
    </div>`).join('');
}

