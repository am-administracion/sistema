  const { data: vias } = await db.from('viaticos').select('monto_anticipado');
  document.getElementById('fin-via').textContent = fp(vias?.reduce((a,v)=>a+(v.monto_anticipado||0),0)||0);

  // Presup vs real
  const pvEl = document.getElementById('fin-pvsr');
  if (!obras?.length) { pvEl.innerHTML = '<div class="empty-state">Sin obras</div>'; }
  else {
    pvEl.innerHTML = obras.map(o => {
      const gObra = gastos?.filter(g=>g.obra_id===o.id).reduce((a,g)=>a+(g.monto||0),0)||0;
      const pct = o.presupuesto ? Math.round(gObra/o.presupuesto*100) : 0;
      const color = pct>80?'var(--red)':pct>50?'var(--amber)':'var(--green)';
      return `<div style="margin-bottom:14px">
        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
          <span style="color:var(--text2)">${o.nombre}</span>
