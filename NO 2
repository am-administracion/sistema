function showAdminTab(tab) {
  ['sueldos','permisos','ordenes'].forEach(t => {
    document.getElementById('admin-'+t).style.display = t===tab?'block':'none';
  });
  document.querySelectorAll('.admin-tab').forEach((btn,i) => {
    const tabs = ['sueldos','permisos','ordenes'];
    btn.className = 'btn btn-sm ' + (tabs[i]===tab?'btn-primary':'btn-ghost') + ' admin-tab';
  });
}

