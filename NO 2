const TITLES = { dashboard:'Dashboard', ariel:'Panel de Ariel', kanban:'Tablero de obras', reporte:'Reporte diario', financiero:'Estado financiero', comisiones:'Comisiones', viaticos:'Viáticos', tickets:'Tickets IA', admin:'Administración' };
function navigate(id, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('sec-' + id).classList.add('active');
  if (el) el.classList.add('active');
  document.getElementById('topbar-title').textContent = TITLES[id] || id;
}

// ============================================================
// FORMATTERS
// ============================================================
function fp(n) {
  if (n == null || isNaN(n)) return '—';
  if (Math.abs(n) >= 1000000) return '$' + (n/1000000).toFixed(1) + 'M';
  if (Math.abs(n) >= 1000) return '$' + Math.round(n/1000) + 'K';
  return '$' + parseInt(n).toLocaleString('es-AR');
}
function fd(d) {
  if (!d) return '—';
  const dt = new Date(d + 'T12:00:00');
  return dt.toLocaleDateString('es-AR', { day:'2-digit', month:'2-digit' });
}
function estadoChip(e) {
  const m = { en_curso:'chip-green', demorada:'chip-amber', iniciando:'chip-blue', pausada:'chip-gray', cerrada:'chip-gray', cotizacion:'chip-purple', adjudicada:'chip-blue', entrega:'chip-amber' };
  const l = { en_curso:'En curso', demorada:'Demorada', iniciando:'Iniciando', pausada:'Pausada', cerrada:'Cerrada', cotizacion:'Cotización', adjudicada:'Adjudicada', entrega:'Entrega' };
  return `<span class="chip ${m[e]||'chip-gray'}">${l[e]||e}</span>`;
}
function kpiChip(s) {
  if (s >= 90) return '<span class="chip chip-green">Excelente</span>';
  if (s >= 75) return '<span class="chip chip-blue">Muy bueno</span>';
  if (s >= 60) return '<span class="chip chip-amber">Aceptable</span>';
  return '<span class="chip chip-red">Por mejorar</span>';
}
function kpiBono(s) { return s>=90?8:s>=75?6:s>=60?4:s>=40?3:0; }

