        <div style="font-size:11px;color:var(--text3);margin-top:3px">${pct}% del presupuesto usado</div>
      </div>`;
    }).join('');
  }

  // Por categoría
  const catEl = document.getElementById('fin-cats');
  if (!gastos?.length) { catEl.innerHTML = '<div class="empty-state">Sin gastos</div>'; return; }
  const byCat = {};
  gastos.forEach(g => { byCat[g.categoria||'Otro'] = (byCat[g.categoria||'Otro']||0)+(g.monto||0); });
  catEl.innerHTML = Object.entries(byCat).sort((a,b)=>b[1]-a[1]).map(([cat,monto])=>`
    <div style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
        <span style="color:var(--text2)">${cat}</span><span style="font-family:var(--mono);color:var(--text)">${fp(monto)}</span>
      </div>
      <div class="progress" style="margin-top:0"><div class="progress-fill" style="width:${Math.round(monto/totalG*100)}%;background:var(--accent)"></div></div>
    </div>`).join('');
}

