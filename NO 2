async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-password').value;
  const btn = document.getElementById('login-btn');
  const errEl = document.getElementById('login-error');
  errEl.style.display = 'none';
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Ingresando...';
  const { data, error } = await db.auth.signInWithPassword({ email, password: pass });
  if (error) {
    errEl.textContent = 'Email o contraseña incorrectos.';
    errEl.style.display = 'block';
    btn.disabled = false; btn.textContent = 'Ingresar al sistema'; return;
  }
  currentUser = data.user;
  await loadUsuario(email);
  showApp();
}

async function loadUsuario(email) {
  const { data } = await db.from('usuarios').select('*').eq('email', email).single();
  currentUsuario = data;
  if (data) {
    const ini = data.nombre.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase();
